llama-bin/

# ─── IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Docker ──────────────────────────────────────────
.docker/

# ─── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db
